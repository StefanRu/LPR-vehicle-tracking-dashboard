# Copy to .env and edit. Never commit the real .env.

# ---- UniFi Protect connection ----
# Just the host/IP. No scheme, no trailing slash. Port separately.
PROTECT_HOST=192.168.0.1
PROTECT_PORT=443

# A LOCAL Protect admin account (created in UniFi OS → Admins & Users).
# Ubiquiti SSO accounts do NOT work with uiprotect. 2FA must be disabled
# on this account. Give it Protect View-only access if the role allows it.
PROTECT_USERNAME=lpr-app
PROTECT_PASSWORD=replace-with-a-long-random-password

# UDMs ship with a self-signed cert; keep false unless you've installed a
# real one.
PROTECT_VERIFY_SSL=false

# ---- Direction classification ----
# Leave both empty to use the first-seen / last-seen heuristic on whatever
# camera fires. Fill them in once you've called GET /api/cameras to see
# the ids.
ENTRY_CAMERA_IDS=
EXIT_CAMERA_IDS=

# ---- Dashboard behaviour ----
KNOWN_PLATES_FILE=/opt/lpr/known_plates.yaml
LOOKBACK_HOURS=24
TIMEZONE=Europe/Paris
PORT=8080
