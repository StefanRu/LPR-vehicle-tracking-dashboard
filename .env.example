# Copy to .env and edit
PROTECT_HOST=https://192.168.1.1
PROTECT_API_KEY=paste-your-protect-integration-api-key-here
PROTECT_VERIFY_TLS=false

# Leave both empty to use the first-seen/last-seen heuristic on a single camera.
# Fill these in once you've called GET /api/cameras to discover the ids.
ENTRY_CAMERA_IDS=
EXIT_CAMERA_IDS=

KNOWN_PLATES_FILE=/data/known_plates.yaml
LOOKBACK_HOURS=24
TIMEZONE=Europe/Paris
